{
  "realm": "flowforge",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full CRUD on automations, host groups, DLQ management",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "operator",
        "description": "Read/write automations, trigger webhooks, view/cancel jobs",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "viewer",
        "description": "Read-only: list automations, list jobs, view outputs",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "flowforge-webapi",
      "name": "FlowForge Web API",
      "description": "Confidential client — authorization code + client credentials",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "flowforge-webapi-secret",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://webapi:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "flowforge-webapi-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "flowforge-webapi",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "flowforge-jobautomator",
      "name": "FlowForge Job Automator",
      "description": "Confidential M2M client — client credentials only",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "flowforge-jobautomator-secret",
      "redirectUris": [],
      "webOrigins": [],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "flowforge-webapi-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "flowforge-webapi",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "flowforge-frontend",
      "name": "FlowForge Frontend",
      "description": "Public client — authorization code + PKCE (future UI)",
      "enabled": true,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "flowforge-webapi-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "flowforge-webapi",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "web-origins",
    "profile",
    "roles",
    "email",
    "acr"
  ],
  "defaultOptionalClientScopes": [
    "offline_access",
    "address",
    "phone",
    "microprofile-jwt"
  ]
}