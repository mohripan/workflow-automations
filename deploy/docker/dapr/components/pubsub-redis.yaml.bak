# Fallback: Rename this to pubsub-kafka.yaml and remove the Kafka component
# to use Redis Streams as the Dapr pub/sub backend instead of Kafka.
apiVersion: dapr.io/v1alpha1
kind: Component
metadata:
  name: flowforge-pubsub
spec:
  type: pubsub.redis
  version: v1
  metadata:
    - name: redisHost
      value: "redis:6379"
    - name: redisPassword
      value: ""
    - name: consumerID
      value: "{appid}"
